# =====================================================================
# Travelers Archive — environment variable template
# =====================================================================
# Copy to `.env` and fill in real values. `.env` is gitignored.
# On the Pi, this file lives inside the container as /app/.env and is
# loaded by app/config.py.

# -- core config -------------------------------------------------------

# `dev` enables the fake-login endpoints in app/auth_dev.py.
# `production` disables them and requires Discord OAuth (app/auth_discord.py).
ENV=dev

# Absolute path inside the container to the SQLite database file.
# In Docker this is mounted from ~/docker/archive-data/ on the Pi.
DATABASE_PATH=/data/archive.db

# Absolute path inside the container to the media folder.
MEDIA_PATH=/data/media

# Signed-cookie session secret. MUST be set in production.
# In dev, app/config.py will generate a random one per process if unset
# (sessions will not survive restart, which is fine for dev).
SESSION_SECRET=

# Public hostname (without scheme) — e.g. "archive.havenmap.online".
# Used in Phase 7 for the Discord OAuth redirect URL. Leave blank in
# dev so cookies are host-only.
PUBLIC_HOST=

# -- Discord OAuth (only needed in Phase 7) ----------------------------

DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=https://archive.havenmap.online/api/v1/auth/discord/callback
DISCORD_BOT_TOKEN=

# Guild IDs whose member rolls are pulled by the 30-min sync job.
DISCORD_VH_GUILD_ID=
DISCORD_ARCHIVIST_GUILD_ID=

# -- Haven atlas sync --------------------------------------------------
# The archive pulls live community figures (systems / discoveries /
# contributors) from the main Haven control-room API and caches them for
# the "live from the atlas" civ infoboxes.
#
# On the Pi, leave this as the internal Docker service name — the archive
# container shares the docker_default network with Haven. For local dev
# against prod data, set HAVEN_API_BASE=https://havenmap.online.
HAVEN_API_BASE=http://haven:8005
# Master switch for the background sync job (1/0).
HAVEN_SYNC_ENABLED=1
# Minutes between automatic syncs.
HAVEN_SYNC_INTERVAL_MIN=30
