# Haven smoke + verification test suite — environment variables
# ---------------------------------------------------------------
# Copy this file to `tests/.env` and fill in real values.
# `tests/.env` is gitignored — never commit.

# Where the smoke tier hits Haven backend
# Pi cron mode:    HAVEN_BASE_URL=http://localhost:8005
# Win-dev manual:  HAVEN_BASE_URL=https://havenmap.online
HAVEN_BASE_URL=http://localhost:8005

# Where the smoke tier hits Haven Exchange
# Pi cron mode:    EXCHANGE_BASE_URL=http://localhost:8010
EXCHANGE_BASE_URL=http://localhost:8010

# Username used by the remote-mode poster smoke tests.
# In-process verify tests use the sentinel "smoke_test_user" instead.
POSTER_REMOTE_USERNAME=parker1920

# Galaxy used by atlas poster smoke test
POSTER_REMOTE_GALAXY=Euclid

# Discord webhook URL for failure alerts. NEVER commit a real URL.
# The alerter REDACTS any URL matching this pattern from log/trace bodies
# before posting, but defense in depth — keep this file out of git.
HAVEN_SMOKE_WEBHOOK_URL=https://discord.com/api/webhooks/REPLACE_ME

# Container names (override defaults if production differs)
HAVEN_CONTAINER_NAME=haven-control-room
KEEPER_CONTAINER_NAME=the-keeper
EXCHANGE_CONTAINER_NAME=economy

# Viobot — leave UNSET until art3mis_7129's project is cloned + running.
# When set, pi_check.sh will probe these; when unset, those rows show SKIP.
# VIOBOT_CONTAINER_NAME=viobot
# VIOBOT_SOURCE_PATH=/home/parker/Viobot

# Haven data + photo paths on the Pi (used by pi_check.sh disk checks)
HAVEN_DATA_PATH=/home/parker/haven-data
HAVEN_PHOTOS_PATH=/home/parker/haven-photos
EXCHANGE_DATA_PATH=/home/parker/exchange-data

# Tunables
SMOKE_REQUEST_TIMEOUT_SECONDS=10
SMOKE_SLOW_TIMEOUT_SECONDS=60
