# Grand Festival environment — copy to the host data dir as `.env` (NOT committed).
# On the Pi this lives at: ~/docker/grand-festival-data/.env
#
# Generate a strong admin password:
#   openssl rand -base64 32

ADMIN_PASSWORD=changeme

# --- Optional overrides (sensible defaults exist) ---
# How long an admin stays logged in, in seconds (default 7 days):
# ADMIN_SESSION_TTL=604800
#
# Secure cookie flag. Keep 1 in production (HTTPS via NPM). Set 0 only for
# local http:// testing so the browser will store the session cookie:
# GF_COOKIE_SECURE=1
#
# Data paths (set by docker-compose; only override for non-Docker runs):
# DATA_DIR=/data
# DB_PATH=/data/grand_festival.db
# UPLOAD_DIR=/data/uploads
