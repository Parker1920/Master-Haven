# Copy to .env (gitignored) and adjust. Runtime secrets live in the DATA
# dir's own .env on the Pi — never in the repo.

# Host path docker-compose mounts as /data (DB, uploads, signature.png).
# On the Pi the default sibling dir is correct and this can be omitted.
# Local dev example:
#HAVEN_OPS_DATA=C:/Users/parke/docker/haven-ops-data
HAVEN_OPS_DATA=../haven-ops-data

# Backend settings (pydantic-settings). Inside the container DATA_DIR is
# already set to /data by docker-compose; these matter for bare local dev.
#DATA_DIR=C:/Users/parke/docker/haven-ops-data
#PORT=8090

# Published host port (container always listens on 8090). Override locally if
# something else already owns 8090 (e.g. the VoyagersHaven-Site dev server).
#HAVEN_OPS_PORT=8091

# Shared secret for the voyagershaven.online -> Ops relay hooks
# (/api/hooks/*). Generate with: python -c "import secrets; print(secrets.token_urlsafe(32))"
# The SAME value goes in the site's HAVEN_OPS_TOKEN. Empty = hooks disabled.
#OPS_SERVICE_TOKEN=
