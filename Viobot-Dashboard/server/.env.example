# ── Viobot Dashboard server config ──────────────────────────────────────────
# Copy to .env and fill in. .env is git-ignored.

# HTTP
PORT=8090
HOST=0.0.0.0
NODE_ENV=development

# Where the React dev server runs (used for the post-login redirect + CORS).
WEB_ORIGIN=http://localhost:5173

# ── Discord OAuth2 (from art3mis — Viobot's Discord application) ─────────────
# Until these are set, /api/health reports oauthConfigured:false and login is disabled.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
# Must EXACTLY match a redirect URI registered on the Discord application.
# With the Vite dev proxy this is served through the web origin and proxied to the backend.
DISCORD_REDIRECT_URI=http://localhost:5173/api/auth/callback

# ── Sessions ────────────────────────────────────────────────────────────────
SESSION_SECRET=change-me-to-a-long-random-string
SESSION_COOKIE_NAME=vbd_sid
SESSION_TTL_MS=86400000
# Set true in production (HTTPS only).
SESSION_SECURE=false

# ── Viobot SQLite DB ────────────────────────────────────────────────────────
# Phase 1 opens this READ-ONLY. Point at a LOCAL COPY, never the live file during dev.
# Example (the Jun-5 fixture copied into the project):
#   VIOBOT_DB_PATH=./dev-fixtures/pi_viobot.db
VIOBOT_DB_PATH=./dev-fixtures/pi_viobot.db
