# Viobot Dashboard — Pi env (copy to deploy/.env on the Pi; git-ignored).

PORT=8090
NODE_ENV=production
WEB_DIST=/app/public
# Same-origin static serving → empty (redirects resolve to "/").
WEB_ORIGIN=

# Live Viobot DB, mounted at /app/data by docker-compose.yml.
# The dashboard is a live read-WRITE config editor (backup-before-write + optimistic concurrency).
VIOBOT_DB_PATH=/app/data/viobot.db
# Optional write kill-switch. false (normal): writes persist. true: write endpoints refuse with HTTP 403.
VIOBOT_DB_READONLY=false

# Discord-less login bypass — treats the session as admin of every server Viobot is in.
# DEV-ONLY: keep 0 (off) in this shipped template; enable it only in a local .env for testing.
DEV_LOGIN=0
DEV_USER_NAME=Haven Admin

# Session signing — generate a strong random value on the Pi (e.g. `openssl rand -hex 32`). Never commit a real secret.
SESSION_SECRET=GENERATE-A-STRONG-RANDOM-VALUE
# true for HTTPS/NPM (the normal deploy). Only override to false in a local .env when testing over plain http://<pi>:8091.
SESSION_SECURE=true

# Discord OAuth — leave blank for dev-login testing; fill these to wire real login later.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=
