# Viobot Dashboard — Pi env (copy to deploy/.env on the Pi; git-ignored).

PORT=8090
NODE_ENV=production
WEB_DIST=/app/public
# Same-origin static serving → empty (redirects resolve to "/").
WEB_ORIGIN=

# Live Viobot DB, mounted at /app/data by docker-compose.yml.
# Phase 1 = READ-ONLY (the app sets PRAGMA query_only=ON, so it cannot write).
VIOBOT_DB_PATH=/app/data/viobot.db
VIOBOT_DB_READONLY=true

# First-test login bypass — NO Discord app needed. Treated as admin of every server Viobot is in.
# Set DEV_LOGIN=false (or remove) before any real / public launch.
DEV_LOGIN=1
DEV_USER_NAME=Haven Admin

# Session signing — REPLACE with a long random string on the Pi (e.g. `openssl rand -hex 32`).
SESSION_SECRET=CHANGE-ME-to-a-long-random-string
# false while testing over plain http://<pi>:8091 ; set true once it's behind HTTPS/NPM.
SESSION_SECURE=false

# Discord OAuth — leave blank for dev-login testing; fill these to wire real login later.
DISCORD_CLIENT_ID=
DISCORD_CLIENT_SECRET=
DISCORD_REDIRECT_URI=
